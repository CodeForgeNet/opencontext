# PCSL Environment Configuration
# Copy this file to .env and fill in your own values

# --- Phase 1: Local POC ---
PCSL_MODE=local

# AI Provider API Keys (get from anthropic.com and openai.com)
# ANTHROPIC_API_KEY=your_key_here
# OPENAI_API_KEY=your_key_here

# --- Phase 2: Server ---
# PCSL_SERVER_URL=http://localhost:8000

# Generate a Fernet key with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# PCSL_ENCRYPTION_KEY=your_fernet_key_here

# Generate a secret key with: python -c "import secrets; print(secrets.token_hex(32))"
# SECRET_KEY=your_jwt_secret_key_here
